{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rabesss/codex-desktop-linux/schemas/custom-model-catalog.schema.json",
  "title": "Codex Desktop Linux Custom Model Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "models"],
  "properties": {
    "version": {
      "const": 1
    },
    "providers": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/provider"
      }
    },
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model"
      }
    }
  },
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "base_url": { "type": "string", "minLength": 1 },
        "wire_api": {
          "type": "string",
          "enum": ["responses", "chat", "openai", "anthropic"]
        },
        "env_key": { "type": "string", "minLength": 1 },
        "env_http_headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "http_headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "requires_openai_auth": { "type": "boolean" },
        "auth": {
          "type": "object",
          "additionalProperties": true
        },
        "request_max_retries": { "type": "integer", "minimum": 1 },
        "stream_max_retries": { "type": "integer", "minimum": 1 },
        "stream_idle_timeout_ms": { "type": "integer", "minimum": 1 }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "slug",
        "model",
        "model_provider",
        "display_name",
        "provider_display_name"
      ],
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "model_provider": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "provider_display_name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "context_window": { "type": "integer", "minimum": 1 },
        "max_context_window": { "type": "integer", "minimum": 1 },
        "auto_compact_token_limit": { "type": "integer", "minimum": 1 },
        "default_reasoning_level": { "type": "string", "minLength": 1 },
        "supported_reasoning_levels": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["effort"],
            "properties": {
              "effort": { "type": "string", "minLength": 1 },
              "description": { "type": "string" }
            }
          }
        },
        "default_reasoning_summary": { "type": "string" },
        "reasoning_summary_format": { "type": "string" },
        "supports_reasoning_summaries": { "type": "boolean" },
        "default_verbosity": { "type": "string" },
        "support_verbosity": { "type": "boolean" },
        "apply_patch_tool_type": { "type": "string" },
        "web_search_tool_type": { "type": "string" },
        "supports_search_tool": { "type": "boolean" },
        "supports_parallel_tool_calls": { "type": "boolean" },
        "experimental_supported_tools": {
          "type": "array"
        },
        "truncation_policy": {
          "type": "object",
          "additionalProperties": true
        },
        "input_modalities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["text", "image"]
          }
        },
        "supports_tools": { "type": "boolean" },
        "supports_reasoning": { "type": "boolean" },
        "supports_streaming": { "type": "boolean" },
        "shell_type": { "type": "string" },
        "visibility": { "type": "string" },
        "minimal_client_version": { "type": "string" },
        "supported_in_api": { "type": "boolean" },
        "priority": { "type": "integer" },
        "prefer_websockets": { "type": "boolean" },
        "available_in_plans": {
          "type": "array",
          "items": { "type": "string" }
        },
        "base_instructions": { "type": "string" },
        "source": { "type": "string" },
        "model_catalog_json": { "type": "string" }
      }
    }
  }
}
