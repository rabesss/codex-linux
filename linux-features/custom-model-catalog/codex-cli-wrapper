#!/usr/bin/env bash
set -euo pipefail

resolve_self() {
    readlink -f "$0" 2>/dev/null || printf '%s\n' "$0"
}

resolve_real_codex() {
    local self feature_id wrapper_env_suffix downstream_var configured_cli app_dir
    self="$(resolve_self)"
    feature_id="$(basename "$(dirname "$self")")"
    wrapper_env_suffix="$(printf '%s' "$feature_id" | tr '[:lower:]' '[:upper:]' | tr -c 'A-Z0-9' '_')"
    downstream_var="CODEX_LINUX_FEATURE_WRAPPED_CODEX_CLI_${wrapper_env_suffix}"
    configured_cli="${!downstream_var:-${CODEX_LINUX_FEATURE_WRAPPED_CODEX_CLI:-}}"
    if [ -n "$configured_cli" ] && [ -x "$configured_cli" ] && [ "$(readlink -f "$configured_cli" 2>/dev/null || printf '%s\n' "$configured_cli")" != "$self" ]; then
        readlink -f "$configured_cli" 2>/dev/null || printf '%s\n' "$configured_cli"
        return 0
    fi

    app_dir="$(cd "$(dirname "$self")/../../.." 2>/dev/null && pwd || true)"
    local candidate
    for candidate in \
        "$app_dir/resources/bin/codex" \
        "$HOME/.bun/bin/codex" \
        "$HOME/.npm-global/bin/codex" \
        "${XDG_CONFIG_HOME:-$HOME/.config}/nvm/versions/node/current/bin/codex" \
        "${XDG_CONFIG_HOME:-$HOME/.config}/nvm/versions/node"/*/bin/codex \
        "$HOME/.nvm/versions/node/current/bin/codex" \
        "$HOME/.nvm/versions/node"/*/bin/codex \
        "$HOME/.local/share/pnpm/codex" \
        "$HOME/.local/bin/codex" \
        "/usr/local/bin/codex" \
        "/usr/bin/codex"
    do
        [ -x "$candidate" ] || continue
        if [ "$(readlink -f "$candidate" 2>/dev/null || printf '%s\n' "$candidate")" != "$self" ]; then
            readlink -f "$candidate" 2>/dev/null || printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

toml_string() {
    python3 - "$1" <<'PY'
import json
import sys

print(json.dumps(sys.argv[1]))
PY
}

build_merged_catalog() {
    local codex_home="${CODEX_HOME:-$HOME/.codex}"
    local config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
    local state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
    local official_cache="${CODEX_CUSTOM_MODEL_OFFICIAL_CACHE_JSON:-$codex_home/models_cache.json}"
    local output_dir="${CODEX_LINUX_APP_STATE_DIR:-$state_home/codex-desktop}/custom-model-catalog"
    local output_path="$output_dir/merged-model-catalog.json"
    local custom_catalog_sources=()

    if [ -n "${CODEX_CUSTOM_MODEL_CATALOG_JSON:-}" ]; then
        custom_catalog_sources+=("$CODEX_CUSTOM_MODEL_CATALOG_JSON")
    fi
    custom_catalog_sources+=(
        "$codex_home/custom-models.json"
        "$config_home/codex-desktop/custom-models.json"
    )
    if [ -n "${CODEX_SHIM_MODEL_CATALOG_JSON:-}" ]; then
        custom_catalog_sources+=("$CODEX_SHIM_MODEL_CATALOG_JSON")
    else
        custom_catalog_sources+=("$state_home/codex-shim/custom_model_catalog.json")
    fi
    mkdir -p "$output_dir"

    python3 - "$official_cache" "$output_path" "${custom_catalog_sources[@]}" <<'PY'
import json
import os
import sys

official_cache, output_path, *custom_catalog_sources = sys.argv[1:]

def load_catalog(path):
    if not path or not os.path.exists(path):
        return [], {}
    with open(path, "r", encoding="utf-8") as handle:
        data = json.load(handle)
    models = data.get("models") if isinstance(data, dict) else data
    providers = data.get("providers") if isinstance(data, dict) else {}
    if not isinstance(models, list):
        models = []
    if not isinstance(providers, dict):
        providers = {}
    return [model for model in models if isinstance(model, dict) and isinstance(model.get("slug"), str)], providers

def load_custom_catalogs(paths):
    models = []
    providers = {}
    seen_paths = set()
    for path in paths:
        if not path:
            continue
        resolved = os.path.abspath(os.path.expanduser(path))
        if resolved in seen_paths:
            continue
        seen_paths.add(resolved)
        catalog_models, catalog_providers = load_catalog(resolved)
        models.extend(catalog_models)
        for provider_id, provider in catalog_providers.items():
            providers.setdefault(provider_id, provider)
    return models, providers

official_models, official_providers = load_catalog(official_cache)
custom_models, custom_providers = load_custom_catalogs(custom_catalog_sources)
if not official_models or not custom_models:
    raise SystemExit(1)

DEFAULT_REASONING_LEVELS = [
    {"effort": "low", "description": "Faster, lighter reasoning"},
    {"effort": "medium", "description": "Balanced speed and reasoning"},
    {"effort": "high", "description": "Deeper reasoning"},
    {"effort": "xhigh", "description": "Maximum reasoning where supported"},
]
DEFAULT_PLANS = ["free", "plus", "pro", "team", "business", "enterprise"]

def string_value(value):
    if isinstance(value, str) and value.strip():
        return value.strip()
    if isinstance(value, (int, float)) and not isinstance(value, bool):
        return str(value)
    return None

def positive_int(value):
    if isinstance(value, bool):
        return None
    if isinstance(value, int) and value > 0:
        return value
    if isinstance(value, str):
        try:
            parsed = int(value.strip())
        except ValueError:
            return None
        if parsed > 0:
            return parsed
    return None

def provider_name(provider_id, providers):
    provider = providers.get(provider_id) if isinstance(providers, dict) else None
    if isinstance(provider, dict):
        return string_value(provider.get("name")) or provider_id
    if provider_id == "openai":
        return "OpenAI"
    if provider_id == "codex_shim":
        return "Codex Shim Router"
    return provider_id

def reasoning_levels(model):
    levels = model.get("supported_reasoning_levels")
    if isinstance(levels, list) and levels:
        return levels
    effort_rows = model.get("supported_reasoning_efforts") or model.get("supportedReasoningEfforts")
    if isinstance(effort_rows, list):
        converted = []
        for row in effort_rows:
            if not isinstance(row, dict):
                continue
            effort = string_value(row.get("effort") or row.get("reasoningEffort"))
            if not effort:
                continue
            converted.append({
                "effort": effort,
                "description": string_value(row.get("description")) or "Custom reasoning level",
            })
        if converted:
            return converted
    return list(DEFAULT_REASONING_LEVELS)

def normalize_model(model, default_provider, providers, priority):
    normalized = dict(model)
    slug = string_value(normalized.get("slug"))
    if not slug:
        return None
    provider_id = string_value(normalized.get("model_provider") or normalized.get("modelProvider")) or default_provider
    display_name = (
        string_value(normalized.get("display_name"))
        or string_value(normalized.get("displayName"))
        or string_value(normalized.get("name"))
        or slug
    )
    provider_display_name = (
        string_value(normalized.get("provider_display_name"))
        or string_value(normalized.get("providerDisplayName"))
        or provider_name(provider_id, providers)
    )
    context_window = (
        positive_int(normalized.get("context_window"))
        or positive_int(normalized.get("contextWindow"))
        or positive_int(normalized.get("max_context_window"))
        or positive_int(normalized.get("maxContextWindow"))
        or 128000
    )
    auto_compact_limit = (
        positive_int(normalized.get("auto_compact_token_limit"))
        or positive_int(normalized.get("autoCompactTokenLimit"))
        or max(1, int(context_window * 0.8))
    )
    input_modalities = normalized.get("input_modalities") or normalized.get("inputModalities")
    if not isinstance(input_modalities, list) or not input_modalities:
        input_modalities = ["text"]

    normalized["slug"] = slug
    normalized.setdefault("model", string_value(normalized.get("upstream_model_id") or normalized.get("upstreamModelId")) or slug)
    normalized["model_provider"] = provider_id
    normalized["provider_display_name"] = provider_display_name
    normalized["display_name"] = display_name
    normalized.setdefault("description", f"{display_name} via {provider_display_name}.")
    normalized["context_window"] = context_window
    normalized["max_context_window"] = (
        positive_int(normalized.get("max_context_window"))
        or positive_int(normalized.get("maxContextWindow"))
        or context_window
    )
    normalized["auto_compact_token_limit"] = auto_compact_limit
    normalized.setdefault("truncation_policy", {"mode": "tokens", "limit": min(64000, context_window)})
    normalized.setdefault("default_reasoning_level", string_value(normalized.get("defaultReasoningEffort")) or "medium")
    normalized["supported_reasoning_levels"] = reasoning_levels(normalized)
    normalized.setdefault("default_reasoning_summary", "auto")
    normalized.setdefault("reasoning_summary_format", "experimental")
    normalized.setdefault("supports_reasoning_summaries", True)
    normalized.setdefault("default_verbosity", "low")
    normalized.setdefault("support_verbosity", False)
    normalized.setdefault("apply_patch_tool_type", "freeform")
    normalized.setdefault("web_search_tool_type", "text_and_image")
    normalized.setdefault("supports_search_tool", False)
    normalized.setdefault("supports_parallel_tool_calls", True)
    normalized.setdefault("experimental_supported_tools", [])
    normalized["input_modalities"] = input_modalities
    normalized.setdefault("supports_image_detail_original", False)
    normalized.setdefault("shell_type", "shell_command")
    normalized.setdefault("visibility", "list")
    normalized.setdefault("minimal_client_version", "0.0.1")
    normalized.setdefault("supported_in_api", True)
    normalized.setdefault("availability_nux", None)
    normalized.setdefault("upgrade", None)
    normalized.setdefault("priority", priority)
    normalized.setdefault("prefer_websockets", False)
    normalized.setdefault("available_in_plans", list(DEFAULT_PLANS))
    normalized.setdefault("base_instructions", "You are a coding agent running in Codex through a custom model provider.")
    normalized.setdefault("model_messages", {
        "instructions_template": "You are Codex running on {model_name}. Be a helpful, direct coding collaborator.",
        "instructions_variables": {"model_name": display_name},
    })
    return normalized

all_providers = {}
all_providers.update(custom_providers)
all_providers.update(official_providers)

merged = {}
for index, model in enumerate(official_models):
    normalized = normalize_model(model, "openai", all_providers, 10000 - index)
    if normalized:
        merged[normalized["slug"]] = normalized
for index, model in enumerate(custom_models):
    normalized = normalize_model(model, "codex_shim", all_providers, 1000 - index)
    if normalized:
        merged.setdefault(normalized["slug"], normalized)

providers = {}
providers.update(custom_providers)
providers.update(official_providers)
payload = {"version": 1, "models": list(merged.values())}
if providers:
    payload["providers"] = providers

with open(output_path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, separators=(",", ":"))
    handle.write("\n")

print(output_path)
PY
}

real_codex="$(resolve_real_codex)"

if [ "${1:-}" = "app-server" ]; then
    if merged_catalog="$(build_merged_catalog 2>/dev/null)"; then
        exec "$real_codex" -c "model_catalog_json=$(toml_string "$merged_catalog")" "$@"
    fi
fi

exec "$real_codex" "$@"
